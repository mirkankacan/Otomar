@{
    ViewData["Title"] = "Profilim";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["MetaRobots"] = "noindex, nofollow";
    ViewData["BreadcrumbItems"] = new List<BreadcrumbItem>
    {
        new("Ana Sayfa", "/ana-sayfa"),
        new("Hesabım", "/hesabim"),
        new(ViewData["Title"] as string ?? "Profilim", null)
    };
}

@section Styles {
    <style>
        .profile__avatar-circle {
            width: 80px;
            height: 80px;
            background: var(--secondary-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .profile__avatar-circle span {
            color: #fff;
            font-size: 2.2rem;
            font-weight: 700;
            line-height: 1;
        }

        .profile__header {
            background: var(--bg-offwhite-color);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2rem 2.4rem;
            margin-bottom: 2.4rem;
            display: flex;
            align-items: center;
            gap: 1.6rem;
        }

        .profile__header-info h2 {
            margin-bottom: 0.4rem;
        }

        .profile__header-info p {
            margin: 0;
            color: var(--foreground-sub-color);
            font-size: 1.35rem;
        }

        .profile__block {
            background: var(--body-background-color);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2rem 2.4rem;
            margin-bottom: 2rem;
        }

        .profile__block-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--foreground-color);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 1.8rem;
            padding-bottom: 1.2rem;
            border-bottom: 2px solid var(--border-color);
        }

        .profile__field label {
            display: block;
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--foreground-color);
            margin-bottom: 0.6rem;
        }

        .profile__input {
            width: 100%;
            padding: 1rem 1.4rem;
            border: 1.5px solid var(--border-color);
            border-radius: 8px;
            font-size: 1.4rem;
            color: var(--foreground-color);
            background: var(--body-background-color);
            transition: border-color 0.2s ease;
            outline: none;
        }

        .profile__input:focus {
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 3px rgba(237, 29, 36, 0.1);
        }

        .profile__input.is-conflict {
            border-color: #dc3545;
        }

        .profile__input-hint {
            font-size: 1.2rem;
            color: var(--foreground-sub-color);
            margin-top: 0.4rem;
        }

        .profile__input-hint.is-error {
            color: #dc3545;
        }

        .profile__actions {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-wrap: wrap;
            margin-top: 0.8rem;
        }

        .profile__btn-cancel {
            padding: 0.9rem 2rem;
            border: 1.5px solid var(--border-color);
            border-radius: 8px;
            background: transparent;
            color: var(--foreground-sub-color);
            font-size: 1.4rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: border-color 0.2s, color 0.2s;
        }

        .profile__btn-cancel:hover {
            border-color: var(--foreground-color);
            color: var(--foreground-color);
        }

        #profile-form-loading,
        #password-form-loading {
            display: none;
        }
    </style>
}

<!-- Profilim / Kullanıcı Bilgileri -->
<section class="my__account--section section--padding">
    <div class="container">
        <div class="my__account--section__inner border-radius-10 d-flex">
            <div class="account__left--sidebar">
                <h2 class="account__content--title mb-20">Hesabım</h2>
                <ul class="account__menu">
                    <li class="account__menu--list"><a href="/hesabim">Sipariş Geçmişi</a></li>
                    <li class="account__menu--list"><a href="/liste-sorgu">Liste Sorgular</a></li>
                    <li class="account__menu--list"><a href="/cari/hesap-hareketleri">Cari Hesap Hareketleri</a></li>
                    <li class="account__menu--list active"><a href="/profilim">Kullanıcı Bilgileri</a></li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="account__menu--list"><a href="/siparis/admin/tum-siparisler">Tüm Siparişler</a></li>
                    }
                    <li class="account__menu--list"><a href="javascript:void(0)" onclick="logout()">Çıkış Yap</a></li>
                </ul>
            </div>

            <div class="account__wrapper">
                <div class="account__content account__details">

                    <!-- Profil başlığı -->
                    <div class="profile__header">
                        <div class="profile__avatar-circle" id="profileAvatarCircle">
                            <span id="profileAvatarLetter">?</span>
                        </div>
                        <div class="profile__header-info">
                            <h2 class="account__content--title h4 mb-0" id="profileHeaderName">Yükleniyor...</h2>
                            <p id="profileHeaderEmail"></p>
                        </div>
                    </div>

                    <!-- Kişisel Bilgiler Formu -->
                    <div class="profile__block">
                        <div class="profile__block-title">Kişisel Bilgiler</div>
                        <form id="profileForm" novalidate>
                            <div class="row g-3 mb-20">
                                <div class="col-lg-6 col-md-6">
                                    <div class="profile__field">
                                        <label for="profileName">Ad <span style="color:var(--secondary-color)">*</span></label>
                                        <input class="profile__input" id="profileName" name="name" type="text" placeholder="Adınız" autocomplete="given-name">
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6">
                                    <div class="profile__field">
                                        <label for="profileSurname">Soyad</label>
                                        <input class="profile__input" id="profileSurname" name="surname" type="text" placeholder="Soyadınız" autocomplete="family-name">
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6">
                                    <div class="profile__field">
                                        <label for="profileEmail">E-posta <span style="color:var(--secondary-color)">*</span></label>
                                        <div class="email-input-wrapper position-relative">
                                            <input class="profile__input" id="profileEmail" name="email" type="email" placeholder="ornek@@email.com" autocomplete="email">
                                            <ul id="profileEmailDomainSuggestions" class="email-domain-suggestions list-unstyled mb-0" role="listbox" aria-hidden="true"></ul>
                                        </div>
                                        <p class="profile__input-hint" id="profileEmailHint"></p>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6">
                                    <div class="profile__field">
                                        <label for="profilePhone">Telefon</label>
                                        <input class="profile__input" id="profilePhone" name="phoneNumber" type="tel" placeholder="05XX XXX XX XX" autocomplete="tel">
                                    </div>
                                </div>
                            </div>
                            <div class="profile__actions">
                                <button type="submit" class="primary__btn" id="profileSaveBtn">Kaydet</button>
                                <span id="profile-form-loading" class="text-secondary" style="font-size:1.3rem;">Kaydediliyor...</span>
                            </div>
                        </form>
                    </div>

                    <!-- Şifre Değiştirme Formu -->
                    <div class="profile__block">
                        <div class="profile__block-title">Şifre Değiştir</div>
                        <p style="font-size:1.35rem; color:var(--foreground-sub-color); margin-bottom:1.8rem;">
                            Şifrenizi değiştirmek istemiyorsanız bu alanları boş bırakın.
                        </p>
                        <form id="passwordForm" novalidate>
                            <div class="row g-3 mb-20">
                                <div class="col-lg-4 col-md-6">
                                    <div class="profile__field">
                                        <label for="profileCurrentPassword">Mevcut Şifre <span style="color:var(--secondary-color)">*</span></label>
                                        <input class="profile__input" id="profileCurrentPassword" name="currentPassword" type="password" placeholder="••••••••" autocomplete="current-password">
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <div class="profile__field">
                                        <label for="profileNewPassword">Yeni Şifre <span style="color:var(--secondary-color)">*</span></label>
                                        <input class="profile__input" id="profileNewPassword" name="newPassword" type="password" placeholder="••••••••" autocomplete="new-password">
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <div class="profile__field">
                                        <label for="profileConfirmPassword">Yeni Şifre (Tekrar) <span style="color:var(--secondary-color)">*</span></label>
                                        <input class="profile__input" id="profileConfirmPassword" name="confirmPassword" type="password" placeholder="••••••••" autocomplete="new-password">
                                        <p class="profile__input-hint" id="passwordMatchHint"></p>
                                    </div>
                                </div>
                            </div>
                            <div class="profile__actions">
                                <button type="submit" class="primary__btn" id="passwordSaveBtn">Şifreyi Güncelle</button>
                                <span id="password-form-loading" class="text-secondary" style="font-size:1.3rem;">Kaydediliyor...</span>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(function () {
            initPhoneMask();
            Validator.setupEmailSuggestions('#profileEmail', '#profileEmailDomainSuggestions');
            bindEmailValidation();
            loadProfile();
            bindProfileForm();
            bindPasswordForm();
            bindPasswordMatchCheck();
        });

        // ── Telefon maskesi (IMask) ──────────────────────────────────────────
        function initPhoneMask() {
            if (typeof IMask === 'undefined') return;
            var el = document.getElementById('profilePhone');
            if (!el) return;
            new IMask(el, {
                mask: '+9\\0 Zdd ddd dd dd',
                definitions: { 'Z': /[1-9]/, 'd': /[0-9]/ },
                lazy: false
            });
        }

        // ── E-posta blur validasyonu (format ipucu) ─────────────────────────
        function bindEmailValidation() {
            var $emailInput = $('#profileEmail');
            $emailInput.on('input', function () {
                $('#profileEmailHint').text('').removeClass('is-error');
                $emailInput.removeClass('is-conflict');
            });
            $emailInput.on('blur', function () {
                var val = $(this).val().trim();
                if (val && !Validator.isValidEmail(val)) {
                    $('#profileEmailHint').text('Geçerli bir e-posta adresi giriniz.').addClass('is-error');
                    $emailInput.addClass('is-conflict');
                } else {
                    $('#profileEmailHint').text('').removeClass('is-error');
                    $emailInput.removeClass('is-conflict');
                }
            });
        }

        // ── Profil veri yükleme ──────────────────────────────────────────────
        async function loadProfile() {
            try {
                var data = await makeRequest('/kullanici/profil', 'GET');
                if (!data) return;

                var name = data.name || data.Name || '';
                var surname = data.surname || data.Surname || '';
                var email = data.email || data.Email || '';
                var phone = data.phoneNumber || data.PhoneNumber || '';

                $('#profileName').val(name);
                $('#profileSurname').val(surname);
                $('#profileEmail').val(email);

                // IMask'ı tetikle (dispatch input event)
                if (phone) {
                    var el = document.getElementById('profilePhone');
                    if (el && el.maskRef) {
                        el.maskRef.value = phone;
                        el.maskRef.updateValue();
                    } else {
                        $('#profilePhone').val(phone);
                    }
                }

                var displayName = [name, surname].filter(Boolean).join(' ') || 'Kullanıcı';
                $('#profileHeaderName').text(displayName);
                $('#profileHeaderEmail').text(email);
                $('#profileAvatarLetter').text(name.length > 0 ? name[0].toUpperCase() : '?');
            } catch (e) {
                $('#profileHeaderName').text('Profil yüklenemedi');
            }
        }

        // ── Kişisel bilgiler formu ───────────────────────────────────────────
        function bindProfileForm() {
            $('#profileForm').on('submit', async function (e) {
                e.preventDefault();

                var name = $('#profileName').val().trim();
                var email = $('#profileEmail').val().trim();
                var phone = $('#profilePhone').val().trim();

                if (!name) {
                    toastr.warning('Ad alanı zorunludur.');
                    $('#profileName').focus();
                    return;
                }
                if (!email) {
                    toastr.warning('E-posta alanı zorunludur.');
                    $('#profileEmail').focus();
                    return;
                }
                if (!Validator.isValidEmail(email)) {
                    $('#profileEmailHint').text('Geçerli bir e-posta adresi giriniz.').addClass('is-error');
                    $('#profileEmail').addClass('is-conflict').focus();
                    return;
                }
                if (phone && !Validator.isValidPhone(phone)) {
                    toastr.warning('Geçerli bir telefon numarası giriniz.');
                    $('#profilePhone').focus();
                    return;
                }

                var dto = {
                    name: name,
                    surname: $('#profileSurname').val().trim() || null,
                    email: email,
                    phoneNumber: phone || null
                };

                $('#profileSaveBtn').prop('disabled', true);
                $('#profile-form-loading').show();

                try {
                    await makeRequest('/kullanici/profil', 'PUT', dto);
                    toastr.success('Profil bilgileriniz başarıyla güncellendi.', 'Kaydedildi');

                    var displayName = [dto.name, dto.surname].filter(Boolean).join(' ');
                    $('#profileHeaderName').text(displayName);
                    $('#profileHeaderEmail').text(dto.email);
                    $('#profileAvatarLetter').text(dto.name[0].toUpperCase());
                    $('#profileEmailHint').text('').removeClass('is-error');
                    $('#profileEmail').removeClass('is-conflict');
                } catch (e) {
                    // makeRequest zaten toastr gösterir
                } finally {
                    $('#profileSaveBtn').prop('disabled', false);
                    $('#profile-form-loading').hide();
                }
            });
        }

        // ── Şifre değiştirme formu ───────────────────────────────────────────
        function bindPasswordForm() {
            $('#passwordForm').on('submit', async function (e) {
                e.preventDefault();

                var current = $('#profileCurrentPassword').val();
                var newPass = $('#profileNewPassword').val();
                var confirm = $('#profileConfirmPassword').val();

                if (!current || !newPass || !confirm) {
                    toastr.warning('Tüm şifre alanları zorunludur.');
                    return;
                }
                if (newPass !== confirm) {
                    $('#passwordMatchHint').text('Şifreler uyuşmuyor.').addClass('is-error');
                    $('#profileConfirmPassword').focus();
                    return;
                }

                var dto = {
                    currentPassword: current,
                    newPassword: newPass,
                    confirmPassword: confirm
                };

                $('#passwordSaveBtn').prop('disabled', true);
                $('#password-form-loading').show();

                try {
                    await makeRequest('/kullanici/sifre-degistir', 'POST', dto);
                    toastr.success('Şifreniz başarıyla güncellendi.', 'Kaydedildi');
                    $('#passwordForm')[0].reset();
                    $('#passwordMatchHint').text('').removeClass('is-error').css('color', '');
                } catch (e) {
                    // makeRequest zaten toastr gösterir
                } finally {
                    $('#passwordSaveBtn').prop('disabled', false);
                    $('#password-form-loading').hide();
                }
            });
        }

        // ── Şifre uyuşma kontrolü (real-time) ───────────────────────────────
        function bindPasswordMatchCheck() {
            function check() {
                var newPass = $('#profileNewPassword').val();
                var confirm = $('#profileConfirmPassword').val();
                if (!confirm) {
                    $('#passwordMatchHint').text('').removeClass('is-error').css('color', '');
                    return;
                }
                if (newPass !== confirm) {
                    $('#passwordMatchHint').text('Şifreler uyuşmuyor.').addClass('is-error').css('color', '');
                } else {
                    $('#passwordMatchHint').text('Şifreler uyuşuyor.').removeClass('is-error').css('color', '#198754');
                }
            }

            $('#profileNewPassword, #profileConfirmPassword').on('input', check);
        }
    </script>
}
