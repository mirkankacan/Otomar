@{
    ViewData["Title"] = "Şifre Sıfırla";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["MetaRobots"] = "noindex, nofollow";
}

<!-- Start login section  -->
<div class="login__section section--padding">
    <div class="container">
        <form id="reset-password-form" action="#" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="reset-email" value="@ViewBag.Email">
            <input type="hidden" id="reset-token" value="@ViewBag.Token">
            <div class="login__section--inner">
                <div class="row row-cols-md-2 row-cols-1 d-flex justify-content-center">
                    <div class="col-6">
                        <div class="account__login">
                            <div class="account__login--header mb-25">
                                <h2 class="account__login--header__title mb-10 d-flex align-self-center justify-content-center">
                                    <img src="/assets/img/logo/otomarlogo.webp" alt="OTOMAR logo" style="width:280px" />
                                </h2>
                            </div>
                            <div class="account__login--inner">
                                <p style="font-size:14px;color:#555;margin-bottom:16px;">Yeni şifrenizi belirleyin.</p>
                                <label>
                                    <input class="account__login--input" id="new-password" placeholder="Yeni şifre giriniz..." type="password" required>
                                </label>
                                <label>
                                    <input class="account__login--input" id="confirm-password" placeholder="Şifre tekrar" type="password" required>
                                </label>
                                <button class="account__login--btn primary__btn" type="submit">Şifremi Sıfırla</button>
                                <p class="recaptcha-terms">Bu site reCAPTCHA ile korunmaktadır. Google <a href="https://policies.google.com/privacy" target="_blank">Gizlilik Politikası</a> ve <a href="https://policies.google.com/terms" target="_blank">Hizmet Şartları</a> geçerlidir.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- End login section  -->

@section Scripts {
    <script src="~/assets/js/http-client.js"></script>
    <script>
        document.getElementById('reset-password-form').addEventListener('submit', async function (e) {
            e.preventDefault();
            var password = document.getElementById('new-password').value;
            var confirmPassword = document.getElementById('confirm-password').value;
            if (password !== confirmPassword) {
                if (typeof showErrorToastr === 'function') {
                    showErrorToastr({ title: 'Şifre Sıfırla', detail: 'Şifre ve şifre tekrar eşleşmiyor.' });
                } else {
                    alert('Şifre ve şifre tekrar eşleşmiyor.');
                }
                return;
            }
            var btn = this.querySelector('button[type="submit"]');
            var originalText = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Sıfırlanıyor...';
            try {
                var payload = {
                    email: document.getElementById('reset-email').value,
                    token: document.getElementById('reset-token').value,
                    password: password,
                    confirmPassword: confirmPassword
                };
                await makeRequestWithRecaptcha('/sifre-sifirla', 'POST', payload, 'password_reset');
                if (typeof toastr !== 'undefined') {
                    toastr.success('Şifreniz başarıyla sıfırlandı. Yönlendiriliyorsunuz...', 'Şifre Sıfırla');
                }
                setTimeout(function () { window.location.href = '/giris-yap'; }, 1500);
            } catch (err) {
                btn.disabled = false;
                btn.textContent = originalText;
            }
        });
    </script>
}
