{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "WebApi",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build: WebApi",
            "program": "${workspaceFolder}/Api/Otomar.WebApi/bin/Debug/net10.0/Otomar.WebApi.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Api/Otomar.WebApi",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "WebApp",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build: WebApp",
            "program": "${workspaceFolder}/App/Otomar.WebApp/bin/Debug/net10.0/Otomar.WebApp.dll",
            "args": [],
            "cwd": "${workspaceFolder}/App/Otomar.WebApp",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        }
    ],
    "compounds": [
        {
            "name": "WebApi + WebApp",
            "configurations": ["WebApi", "WebApp"],
            "stopAll": true
        }
    ]
}
